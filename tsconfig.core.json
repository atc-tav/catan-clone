{
  // Purity guard for the portable core. It compiles src/core (and tests) WITHOUT
  // the DOM lib, so any accidental browser/React/Three.js usage in the core that
  // would break the C#/Unity port fails the typecheck. Run via `npm run typecheck`.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "jsx": "react",
    "noEmit": true,
    "plugins": []
  },
  "include": ["src/core", "tests"],
  "exclude": ["node_modules", "dist", ".next"]
}
